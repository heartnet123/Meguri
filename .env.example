# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SITE_URL: The public URL for this app.
# Better Auth/Convex use this to build callback and redirect URLs.
# For local development, this is usually http://localhost:3000.
SITE_URL="http://localhost:3000"

# NEXT_PUBLIC_SITE_URL: Optional client-side mirror of SITE_URL.
# Keep this in sync with SITE_URL when deploying.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Convex deployment values used by the app and auth helpers.
NEXT_PUBLIC_CONVEX_URL="https://your-deployment.convex.cloud"
CONVEX_DEPLOYMENT="dev:your-deployment"
NEXT_PUBLIC_CONVEX_SITE_URL="https://your-deployment.convex.site"
